# ============================================================
# GitHub Tracker — Configuration
# Copiez ce fichier en .env et remplissez vos valeurs
# ============================================================

# --- Telegram ---
# Créez un bot via @BotFather sur Telegram pour obtenir le token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID du chat/groupe/canal où envoyer les notifications
# Pour un chat privé : envoyez un message à @userinfobot
# Pour un groupe     : ajoutez @RawDataBot au groupe
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Intervalle de vérification ---
# Durée (en secondes) entre chaque vérification (défaut: 300 = 5 min)
# Sans token GitHub : max ~60 requêtes/heure → repos * 2 / heure
# Avec token GitHub  : max 5 000 requêtes/heure
CHECK_INTERVAL_SECONDS=300

# --- Interface web ---
# Adresse d'écoute (0.0.0.0 = accessible sur tout le réseau LAN)
WEB_HOST=0.0.0.0

# Port d'écoute
WEB_PORT=8080

# --- GitHub API (optionnel, mais recommandé) ---
# Augmente la limite de l'API de 60 à 5 000 requêtes/heure
# Créez un token sur https://github.com/settings/tokens (pas de scope nécessaire)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
